# Nostr Wallet Connect URL
NWC_URL=
# Backend API URL
NEON_URL=


# NOSTR Private Key (hex format, without 0x prefix)
NOSTR_PRIVKEY=
# Enable NOSTR features like announcements and notifications (set to "true" to enable)
NOSTR_ENABLED=

# Oficial URL of the app
APP_URL=

# Debug mode for testing (NEXT_PUBLIC_TEST=on enables debug buttons and endpoints)
NEXT_PUBLIC_TEST=

# Secret for third-party services (e.g., Vercel) - set this to a random string for security
VERCEL_SECRET=